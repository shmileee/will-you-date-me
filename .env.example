# Copy to .env (gitignored) for LOCAL testing of notifications.
# For PRODUCTION (GitHub Pages), set these as repository secrets named
# WITHOUT the "VITE_" prefix: TG_BOT_TOKEN, TG_CHAT_ID.
# The deploy workflow re-exports them as VITE_* env vars at build time.

# --- Telegram bot ---
# 1. Talk to @BotFather, /newbot, save the HTTP API token.
# 2. Send any message to your new bot from your Telegram account.
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates and copy the chat.id.
VITE_TG_BOT_TOKEN=
VITE_TG_CHAT_ID=

# If neither is set, the form still works — submitting just falls back
# to a console.info log instead of sending anything.
