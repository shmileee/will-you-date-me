# Copy to .env (gitignored) for LOCAL testing of notifications.
# For PRODUCTION (GitHub Pages), set these as repository secrets named
# WITHOUT the "VITE_" prefix: TG_BOT_TOKEN, TG_CHAT_ID, NTFY_TOPIC, DISCORD_WEBHOOK.
# The build workflow re-exports them as VITE_* env vars.

# --- Option A: Telegram (recommended) ---
# 1. Talk to @BotFather, /newbot, save the HTTP API token.
# 2. Send any message to your new bot from your Telegram account.
# 3. Visit https://api.telegram.org/bot<TOKEN>/getUpdates and copy the chat.id.
VITE_TG_BOT_TOKEN=
VITE_TG_CHAT_ID=

# --- Option B: ntfy.sh (zero signup, push to phone) ---
# Pick a long random string. Install ntfy app, subscribe to that topic.
VITE_NTFY_TOPIC=

# --- Option C: Discord webhook ---
# Server settings → Integrations → Webhooks → New webhook → Copy URL.
VITE_DISCORD_WEBHOOK=

# The app picks whichever is set first in this order: Telegram, ntfy, Discord.
# If none are set, the form still works but no notification is sent.
